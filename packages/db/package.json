{
  "name": "@nexushub/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and DB client for NexusHub.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=../../.env.local prisma/seed.ts",
    "migrate-data:card-template-items": "tsx --env-file=../../.env.local prisma/migrations-data/2026-05-12-card-template-items.ts",
    "db:bootstrap-admin": "tsx --env-file=../../.env.local prisma/bootstrap-admin.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.46.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0"
  }
}
