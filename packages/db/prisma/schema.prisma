// =====================================================================
// NexusHub — Prisma schema
// All tables: workspace_id scoped + RLS Postgres policies (see Phase 2).
// =====================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

