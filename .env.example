# =============================================================================
# NexusHub — environment variables (TEMPLATE — copy to .env.local)
# =============================================================================
# SECURITY:
#  - Never commit a real value to this file. Real secrets live in Vercel /
#    Supabase / .env.local only.
#  - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
#    Do NOT put a secret behind that prefix.
#  - Server-only variables MUST be imported via apps/web/lib/env.ts only.
# =============================================================================

# --- App ---------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public base URL used server-side to build OAuth callback URIs.
APP_URL=

# --- Supabase ---------------------------------------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS. Treat as a god-key.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Database (Postgres via Supabase) ---------------------------------------
# Pooled URL for runtime queries (PgBouncer):
DATABASE_URL=
# Direct URL for migrations (Prisma needs this):
DIRECT_URL=

# --- Crypto -----------------------------------------------------------------
# AES-256 key, base64-encoded 32 bytes (44 chars).
# Generate: `openssl rand -base64 32`
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1
# 32-byte base64 secret used to HMAC-sign OAuth `state`. Generate with:
#   openssl rand -base64 32
OAUTH_STATE_SECRET=
# HMAC secret for invitation tokens. Generate: `openssl rand -hex 32`
INVITATION_SECRET=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=invitations@mail.nexushub.app
RESEND_FROM_NAME=NexusHub

# --- Slack integration ------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# --- Microsoft Graph integration -------------------------------------------
# Azure AD app credentials (Entra → App registrations). The redirect URI is
# derived at runtime from APP_URL + /api/oauth/graph/callback — NOT a separate
# env var. See docs/runbooks/microsoft-graph-integration.md.
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# --- Inngest (background jobs) ---------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Upstash Redis (rate limiting) -----------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (monitoring) ---------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- ClamAV (mail attachment antivirus scan, V1.5) --------------------------
# Remote clamd daemon TCP host/port (INSTREAM protocol). See
# packages/integrations/src/antivirus/clamav.ts. When CLAMAV_HOST is unset,
# uploadAttachment fails closed (rejects with SCAN_FAILED) rather than
# skipping the scan.
CLAMAV_HOST=
CLAMAV_PORT=3310

# --- Web Push (notifications, V1) ------------------------------------------
# Generate: `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@nexushub.app
