{
  "name": "@nexushub/web",
  "version": "0.1.0",
  "private": true,
  "description": "NexusHub web app (Next.js 15 + App Router).",
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
